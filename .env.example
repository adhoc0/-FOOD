# ─────────────────────────────────────────────
# Bu dosyayı kopyalayıp .env olarak kaydet
# Gerçek değerleri .env dosyasına yaz
# ─────────────────────────────────────────────

SECRET_KEY=replace-with-a-random-secret-of-at-least-50-characters

DEBUG=False

ALLOWED_HOSTS=127.0.0.1,localhost

CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# PostgreSQL
DB_NAME=food_db
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=5432
